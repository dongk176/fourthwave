generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas  = ["fourthwave"]
}

model ResultAsset {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  artist        String   @default("FourthWave Artist")
  description   String   @default("")
  type          String
  mediaKey      String?  @map("media_key")
  mediaData     Bytes?   @map("media_data")
  mediaMime     String   @map("media_mime")
  thumbnailKey  String?  @map("thumbnail_key")
  thumbnailData Bytes?   @map("thumbnail_data")
  thumbnailMime String?  @map("thumbnail_mime")
  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  @@map("result_assets")
  @@schema("fourthwave")
}

model FaqItem {
  id        String   @id @default(uuid()) @db.Uuid
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  @@map("faq_items")
  @@schema("fourthwave")
}

model Inquiry {
  id               String   @id @default(uuid()) @db.Uuid
  source           String
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  email            String
  message          String
  age              Int?
  subscribeUpdates Boolean  @default(false) @map("subscribe_updates")
  programInterest  String?  @map("program_interest")
  zoomCallKst      String?  @map("zoom_call_kst")
  createdAt        DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  @@map("inquiries")
  @@schema("fourthwave")
}
