{
  "name": "fourthwave-production",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "db:generate": "node scripts/prisma-env-run.mjs generate",
    "db:push": "node scripts/prisma-env-run.mjs db push --schema prisma/schema.prisma",
    "db:migrate:dev": "node scripts/prisma-env-run.mjs migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "node scripts/prisma-env-run.mjs migrate deploy --schema prisma/schema.prisma",
    "db:migrate:status": "node scripts/prisma-env-run.mjs migrate status --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.908.0",
    "@aws-sdk/s3-request-presigner": "^3.908.0",
    "@prisma/client": "^6.16.3",
    "next": "latest",
    "prisma": "^6.16.3",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "latest",
    "@tailwindcss/forms": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "latest"
  }
}
